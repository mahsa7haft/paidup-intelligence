DATABASE_URL=postgresql://user:password@host:5432/intelligence_db
# Read-only role for the agent / MCP / /ask path (intelligence_ro). Falls back to
# DATABASE_URL if unset. See docs/security-roles.sql and ADR 013.
DATABASE_URL_READONLY=postgresql://intelligence_ro:password@host:5432/intelligence_db
PAIDUP_DATABASE_URL=postgresql://user:password@host:5432/paidup_db
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
THEYWORKFORYOU_API_KEY=your-twfy-key-here
REDIS_URL=redis://localhost:6379
